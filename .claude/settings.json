{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/sync-planning-pack.ps1",
              "-Trigger",
              "commit"
            ]
          },
          {
            "type": "command",
            "if": "Bash(git merge *)",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/sync-planning-pack.ps1",
              "-Trigger",
              "merge"
            ]
          }
        ]
      }
    ]
  }
}
