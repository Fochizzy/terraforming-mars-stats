{
  "name": "terraforming-mars-stats",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/apply-lineup-effects-polish.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/apply-lineup-effects-polish.mjs && node scripts/validate-claude-project-context.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pretest": "node scripts/apply-lineup-effects-polish.mjs && node scripts/validate-claude-project-context.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests",
    "prepreview": "node scripts/apply-lineup-effects-polish.mjs && node scripts/validate-claude-project-context.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "predeploy": "node scripts/apply-lineup-effects-polish.mjs && node scripts/validate-claude-project-context.mjs",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "validate:claude-context": "node scripts/validate-claude-project-context.mjs",
    "test:planning-pack": "node scripts/planning-pack/test-validate-claude-project-context.mjs && python scripts/planning-pack/test_git_source.py",
    "catalog:fetch": "tsx scripts/catalog/fetch-hadronikle.ts",
    "catalog:publish": "tsx scripts/catalog/publish-reference-data.ts",
    "catalog:sync:upstream": "tsx scripts/catalog/sync-terraforming-mars-upstream.ts",
    "auth:configure": "node scripts/auth/configure-email-auth.mjs",
    "auth:configure:dry-run": "node scripts/auth/configure-email-auth.mjs --dry-run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.1",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
