# runtime env (Cloudflare Worker + local app runtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_STORAGE_BUCKET_IMPORT_EVIDENCE=tm-import-evidence
RESEND_API_KEY=

# Pins the Server Actions encryption key across builds. Put the real value in
# .env.local (build time) AND as a Worker secret with the SAME value (runtime):
#   wrangler secret put NEXT_SERVER_ACTIONS_ENCRYPTION_KEY
# Without this, every deploy rotates the key and breaks already-open tabs with
# "Server Action ... was not found on the server". Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# local-only admin and catalog script env
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_STORAGE_BUCKET_CARD_FULL=tm-card-full
SUPABASE_STORAGE_BUCKET_CARD_THUMBS=tm-card-thumbs
