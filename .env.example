# runtime env (Cloudflare Worker + local app runtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_STORAGE_BUCKET_IMPORT_EVIDENCE=tm-import-evidence

# local-only admin and catalog script env
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_STORAGE_BUCKET_CARD_FULL=tm-card-full
SUPABASE_STORAGE_BUCKET_CARD_THUMBS=tm-card-thumbs

# local-only Supabase Auth management env
# Create SUPABASE_ACCESS_TOKEN in the Supabase account dashboard. Never deploy it to the Worker.
SUPABASE_ACCESS_TOKEN=
# Optional when Resend SMTP is already configured in Supabase. Supply it to install/rotate SMTP credentials.
RESEND_API_KEY=
SUPABASE_AUTH_SITE_URL=https://tm-stats.com
SUPABASE_AUTH_FROM_EMAIL=no-reply@mail.tm-stats.com
SUPABASE_AUTH_SENDER_NAME=Terraforming Mars Stats
SUPABASE_AUTH_EMAILS_PER_HOUR=30
SUPABASE_AUTH_EMAIL_MIN_INTERVAL_SECONDS=60
